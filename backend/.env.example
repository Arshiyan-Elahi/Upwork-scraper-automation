# =============================================================================
# Upwork-AI-intelligence — Backend environment variables
# Copy this file to .env and fill in values. Never commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./freelance.db

# -----------------------------------------------------------------------------
# Encryption (required to store user LLM keys from Settings)
# -----------------------------------------------------------------------------
# Generate once: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=your-fernet-key-here

# -----------------------------------------------------------------------------
# LLM providers — optional .env fallbacks when no user key is stored in Settings
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# Optional model overrides
# GEMINI_MODEL=gemini-2.0-flash
# GROQ_MODEL=llama-3.3-70b-versatile
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# CORS (optional — comma-separated frontend origins)
# -----------------------------------------------------------------------------
# Localhost dev origins are always allowed. To allow a DEPLOYED frontend, add its
# origin(s) here (added on top of the localhost defaults — no IP is hardcoded):
# CORS_ALLOW_ORIGINS=http://45.11.231.77:3000,https://app.example.com
#
# Advanced: CORS_ORIGINS overrides the localhost default base (rarely needed).
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5175

# -----------------------------------------------------------------------------
# Chrome extension webhook (optional)
# -----------------------------------------------------------------------------
# WEBHOOK_SECRET=your-shared-secret

# -----------------------------------------------------------------------------
# Auth / JWT (required for stable login sessions)
# -----------------------------------------------------------------------------
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(48))"
# If unset, a temporary per-process secret is used (sessions drop on restart).
# JWT_SECRET=your-long-random-secret
# JWT_EXPIRE_MINUTES=10080
