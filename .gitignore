# ---------------------------------------------------------------------------
# Secrets / environment
# ---------------------------------------------------------------------------
.env
.env.*
*.env
**/.env
**/.env.*

# ...but DO keep example/template env files (no real secrets)
!.env.example
!.env.sample
!.env.template
!**/.env.example
!**/.env.sample
!**/.env.template

# ---------------------------------------------------------------------------
# Databases (SQLite)
# ---------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/
ENV/
**/.venv/
**/venv/

# ---------------------------------------------------------------------------
# Node / frontend
# ---------------------------------------------------------------------------
node_modules/
**/node_modules/
dist/
**/dist/
*.local

# ---------------------------------------------------------------------------
# Browser automation profiles
# ---------------------------------------------------------------------------
chrome-profile/
**/chrome-profile/

# ---------------------------------------------------------------------------
